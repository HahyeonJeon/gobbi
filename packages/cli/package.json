{
  "name": "@gobbitools/cli",
  "version": "0.4.5",
  "description": "Gobbi CLI — workflow orchestration and docs management for Claude Code",
  "type": "module",
  "bin": {
    "gobbi": "./bin/gobbi.js"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun --external playwright --external sharp",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0",
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "license": "MIT",
  "author": "HahyeonJeon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HahyeonJeon/gobbi.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/HahyeonJeon/gobbi#readme",
  "keywords": [
    "claude-code",
    "claude",
    "harness",
    "orchestration",
    "ai-agent",
    "workflow",
    "claudex",
    "claude-experience",
    "claude-docs",
    "media",
    "image-analysis",
    "video-analysis",
    "screenshot"
  ],
  "devDependencies": {
    "bun-types": "^1.3.12",
    "fast-check": "^4.6.0"
  }
}
