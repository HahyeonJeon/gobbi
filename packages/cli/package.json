{
  "name": "@gobbitools/cli",
  "version": "0.5.0",
  "description": "Gobbi CLI — workflow orchestration and docs management for Claude Code",
  "type": "module",
  "bin": {
    "gobbi": "./bin/gobbi.js"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "files": [
    "bin",
    "dist",
    ".gobbi/projects/gobbi/skills",
    ".gobbi/projects/gobbi/agents",
    ".gobbi/projects/gobbi/rules"
  ],
  "scripts": {
    "gen:predicates": "bun run scripts/gen-predicate-names.ts",
    "sync:template-bundle": "bun run scripts/sync-template-bundle.ts",
    "regen-schema": "bun -e \"import('./src/specs/_schema/v1.ts').then(m => process.stdout.write(JSON.stringify(m.StepSpecSchema, null, 2) + '\\n'))\" > src/specs/_schema/v1.json",
    "prebuild": "bun run gen:predicates",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun --external playwright --external sharp",
    "build:safe": "bun run gen:predicates && bun build ./src/cli.ts --outdir ./dist.new --target bun --external playwright --external sharp && mv ./dist.new/cli.js ./dist/cli.js && rm -rf ./dist.new",
    "pretypecheck": "bun run gen:predicates",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run sync:template-bundle"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "fast-json-patch": "^3.1.1"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0",
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "license": "MIT",
  "author": "HahyeonJeon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HahyeonJeon/gobbi.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/HahyeonJeon/gobbi#readme",
  "keywords": [
    "claude-code",
    "claude",
    "harness",
    "orchestration",
    "ai-agent",
    "workflow",
    "claudex",
    "claude-experience",
    "claude-docs",
    "media",
    "image-analysis",
    "video-analysis",
    "screenshot"
  ],
  "devDependencies": {
    "bun-types": "^1.3.12",
    "fast-check": "^4.6.0"
  }
}
