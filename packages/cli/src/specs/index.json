{
  "$schema": "https://gobbi.dev/schemas/workflow-graph/v1.json",
  "version": 1,
  "entry": "ideation",
  "terminal": ["memorization"],
  "steps": [
    {
      "id": "ideation",
      "spec": "./ideation/spec.json",
      "substates": ["discussing", "researching"]
    },
    {
      "id": "ideation_eval",
      "spec": "./evaluation/spec.json",
      "evalFor": "ideation"
    },
    {
      "id": "plan",
      "spec": "./plan/spec.json"
    },
    {
      "id": "plan_eval",
      "spec": "./evaluation/spec.json",
      "evalFor": "plan"
    },
    {
      "id": "execution",
      "spec": "./execution/spec.json"
    },
    {
      "id": "execution_eval",
      "spec": "./evaluation/spec.json",
      "evalFor": "execution"
    },
    {
      "id": "memorization",
      "spec": "./memorization/spec.json"
    }
  ],
  "transitions": [
    {
      "from": "ideation",
      "to": "ideation_eval",
      "condition": "evalIdeationEnabled",
      "trigger": "workflow.step.exit",
      "label": "ideation exit → optional ideation_eval"
    },
    {
      "from": "ideation",
      "to": "plan",
      "condition": "evalIdeationDisabled",
      "trigger": "workflow.step.exit",
      "label": "ideation exit → plan (eval skipped)"
    },
    {
      "from": "ideation_eval",
      "to": "ideation",
      "condition": "verdictRevise",
      "trigger": "decision.eval.verdict",
      "feedback": true,
      "label": "ideation_eval revise → re-enter ideation"
    },
    {
      "from": "ideation_eval",
      "to": "plan",
      "condition": "verdictPass",
      "trigger": "decision.eval.verdict",
      "label": "ideation_eval pass → plan"
    },
    {
      "from": "plan",
      "to": "plan_eval",
      "condition": "evalPlanEnabled",
      "trigger": "workflow.step.exit",
      "label": "plan exit → optional plan_eval"
    },
    {
      "from": "plan",
      "to": "execution",
      "condition": "evalPlanDisabled",
      "trigger": "workflow.step.exit",
      "label": "plan exit → execution (eval skipped)"
    },
    {
      "from": "plan_eval",
      "to": "plan",
      "condition": "verdictRevise",
      "trigger": "decision.eval.verdict",
      "feedback": true,
      "label": "plan_eval revise → re-enter plan"
    },
    {
      "from": "plan_eval",
      "to": "execution",
      "condition": "verdictPass",
      "trigger": "decision.eval.verdict",
      "label": "plan_eval pass → execution"
    },
    {
      "from": "execution",
      "to": "execution_eval",
      "condition": "always",
      "trigger": "workflow.step.exit",
      "label": "execution exit → mandatory execution_eval"
    },
    {
      "from": "execution_eval",
      "to": "memorization",
      "condition": "verdictPass",
      "trigger": "decision.eval.verdict",
      "label": "execution_eval pass → memorization"
    },
    {
      "from": "execution_eval",
      "to": "error",
      "condition": "feedbackCapExceeded",
      "trigger": "decision.eval.verdict",
      "label": "execution_eval revise but cap exceeded → error"
    },
    {
      "from": "execution_eval",
      "to": "ideation",
      "condition": "loopTargetIdeation",
      "trigger": "decision.eval.verdict",
      "feedback": true,
      "label": "execution_eval revise loopTarget=ideation"
    },
    {
      "from": "execution_eval",
      "to": "plan",
      "condition": "loopTargetPlan",
      "trigger": "decision.eval.verdict",
      "feedback": true,
      "label": "execution_eval revise loopTarget=plan"
    },
    {
      "from": "execution_eval",
      "to": "execution",
      "condition": "loopTargetExecution",
      "trigger": "decision.eval.verdict",
      "feedback": true,
      "label": "execution_eval revise loopTarget=execution"
    },
    {
      "from": "memorization",
      "to": "done",
      "condition": "always",
      "trigger": "workflow.finish",
      "label": "memorization complete → done"
    },
    {
      "from": "ideation",
      "to": "error",
      "condition": "stepTimeoutFired",
      "trigger": "workflow.step.timeout",
      "label": "ideation timeout → error"
    },
    {
      "from": "ideation_eval",
      "to": "error",
      "condition": "stepTimeoutFired",
      "trigger": "workflow.step.timeout",
      "label": "ideation_eval timeout → error"
    },
    {
      "from": "plan",
      "to": "error",
      "condition": "stepTimeoutFired",
      "trigger": "workflow.step.timeout",
      "label": "plan timeout → error"
    },
    {
      "from": "plan_eval",
      "to": "error",
      "condition": "stepTimeoutFired",
      "trigger": "workflow.step.timeout",
      "label": "plan_eval timeout → error"
    },
    {
      "from": "execution",
      "to": "error",
      "condition": "stepTimeoutFired",
      "trigger": "workflow.step.timeout",
      "label": "execution timeout → error"
    },
    {
      "from": "execution_eval",
      "to": "error",
      "condition": "stepTimeoutFired",
      "trigger": "workflow.step.timeout",
      "label": "execution_eval timeout → error"
    },
    {
      "from": "memorization",
      "to": "error",
      "condition": "stepTimeoutFired",
      "trigger": "workflow.step.timeout",
      "label": "memorization timeout → error"
    },
    {
      "from": "ideation_eval",
      "to": "ideation",
      "condition": "skipRequested",
      "trigger": "workflow.step.skip",
      "feedback": true,
      "label": "user skip → restart ideation"
    },
    {
      "from": "plan",
      "to": "ideation",
      "condition": "skipRequested",
      "trigger": "workflow.step.skip",
      "feedback": true,
      "label": "user skip → restart ideation"
    },
    {
      "from": "plan_eval",
      "to": "ideation",
      "condition": "skipRequested",
      "trigger": "workflow.step.skip",
      "feedback": true,
      "label": "user skip → restart ideation"
    },
    {
      "from": "execution",
      "to": "ideation",
      "condition": "skipRequested",
      "trigger": "workflow.step.skip",
      "feedback": true,
      "label": "user skip → restart ideation"
    },
    {
      "from": "execution_eval",
      "to": "ideation",
      "condition": "skipRequested",
      "trigger": "workflow.step.skip",
      "feedback": true,
      "label": "user skip → restart ideation"
    },
    {
      "from": "memorization",
      "to": "ideation",
      "condition": "skipRequested",
      "trigger": "workflow.step.skip",
      "feedback": true,
      "label": "user skip → restart ideation"
    },
    {
      "from": "error",
      "to": "done",
      "condition": "abortRequested",
      "trigger": "workflow.abort",
      "label": "user abort from error → done"
    },
    {
      "from": "error",
      "to": "ideation",
      "condition": "resumeTargetIdeation",
      "trigger": "workflow.resume",
      "label": "resume from error → ideation"
    },
    {
      "from": "error",
      "to": "plan",
      "condition": "resumeTargetPlan",
      "trigger": "workflow.resume",
      "label": "resume from error → plan"
    },
    {
      "from": "error",
      "to": "execution",
      "condition": "resumeTargetExecution",
      "trigger": "workflow.resume",
      "label": "resume from error → execution"
    },
    {
      "from": "error",
      "to": "memorization",
      "condition": "resumeTargetMemorization",
      "trigger": "workflow.resume",
      "label": "resume from error → memorization (force-memorization pathway)"
    }
  ]
}
