node_modules/
.claude/project/*/note/
.claude/worktrees/
.claude/.env
.claude/gobbi.json
.claude/gobbi.json.lock

# .gobbi/ — whitelist pattern.
# Ignore workspace-level files (e.g. .gobbi/settings.json, .gobbi/config.db),
# but track per-project content under .gobbi/projects/<name>/ except for
# per-session runtime state (sessions/, rawdata/) and per-project settings.
.gobbi/*
!.gobbi/projects/
.gobbi/projects/*/sessions/
.gobbi/projects/*/rawdata/
.gobbi/projects/*/settings.json

dist/
packages/*/dist/
packages/*/node_modules/

# Template-bundle mirror (built by `packages/cli/scripts/sync-template-bundle.ts`
# as the `prepack` hook). Source of truth lives at the workspace-root
# `.gobbi/projects/gobbi/{skills,agents,rules}/`; this copy only exists
# so `npm pack` can ship it inside the tarball.
packages/cli/.gobbi/
