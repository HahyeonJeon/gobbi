{
  "permissions": {
    "allow": [
      "Skill(gobbi)",
      "Skill(_orchestration)",
      "Skill(_gotcha)",
      "Skill(_claude)",
      "Skill(_skills)",
      "Skill(_agents)",
      "Skill(_rules)",
      "Skill(_project)",
      "Skill(_discuss)",
      "Skill(_ideation)",
      "Skill(_plan)",
      "Skill(_research)",
      "Skill(_delegation)",
      "Skill(_execution)",
      "Skill(_evaluation)",
      "Skill(_note)",
      "Skill(_note:*)",
      "Skill(_collection)",
      "Skill(_memorization)",
      "Skill(_notification)",
      "Skill(_git)",
      "Skill(_gobbi-rule-container)",
      "Skill(_innovation)",
      "Skill(_best-practice)",
      "Agent(gobbi-agent)",
      "Agent(__executor)",
      "Agent(__pi)",
      "Agent(__researcher)",
      "Agent(_agent-evaluator)",
      "Agent(_skills-evaluator)",
      "Agent(_project-evaluator)",
      "WebSearch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "gobbi workflow init",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "gobbi workflow guard",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "gobbi workflow capture-plan",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "gobbi workflow capture-subagent",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "gobbi workflow stop",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  }
}
